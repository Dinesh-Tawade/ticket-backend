# ==================== SERVER ====================
PORT=5000
HOST=localhost
NODE_ENV=development

# For production, set:
# NODE_ENV=production
# HOST=0.0.0.0
# BASE_URL=https://api.yourapp.com

# ==================== DATABASE ====================
MONGODB_URI=mongodb://localhost:27017/booking_app

# For production, use Atlas connection string:
# MONGODB_URI=mongodb+srv://globalinfotechindia07_db_user:XvyXT8JvWSAgfzuK@cluster0.bzaryvt.mongodb.net/booking_app?retryWrites=true&w=majority&appName=Cluster0

# ==================== AUTH & SECURITY ====================
JWT_SECRET=your_super_secret_jwt_key_change_this
ENCRYPTION_KEY=your_32_byte_encryption_key_here_12345

# ==================== CORS ====================
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:3000,http://192.168.1.10:3000

# For production:
# CORS_ORIGINS=https://yourapp.com,https://www.yourapp.com

# ==================== FILE UPLOADS ====================
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=5242880
BODY_LIMIT=50mb

# ==================== OPTIONAL: PUBLIC BASE URL ====================
# Used in server startup logs. Set this in production to your actual domain.
# BASE_URL=https://api.yourapp.com